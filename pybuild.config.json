{
  "javaHome17": "/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home",
  "adb": "/usr/local/bin/adb",
  "apps": {
    "supervisor": {
      "dir": ".",
      "appName": "CGuardPro Supervisor",
      "bundleId": "com.cguardpro.supervisor",
      "android": {
        "keystore": "android/cguardpro-supervisor-release.keystore",
        "keystorePassword": "ENV:CGUARDPRO_KEYSTORE_PASS",
        "keyAlias": "cguardprosupervisor",
        "keyPassword": "ENV:CGUARDPRO_KEY_PASS",
        "dname": "CN=CGuardPro Supervisor, O=CGuardPro, L=Quito, C=EC"
      },
      "ios": {
        "teamId": "ENV:CGUARDPRO_TEAM_ID",
        "ascApiKeyId": "ENV:ASC_KEY_ID",
        "ascApiIssuerId": "ENV:ASC_ISSUER_ID",
        "ascApiKeyPath": "~/.appstoreconnect/private_keys/AuthKey.p8"
      }
    }
  }
}
