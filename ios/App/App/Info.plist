<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>remote-notification</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>CGuardPro Supervisor</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>CGuardPro Supervisor usa la cámara para tomar fotos de verificación en las paradas de tu ruta de patrullaje.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>CGuardPro Supervisor usa tu ubicación para el marcaje de entrada, la navegación a cada parada y la verificación de tu ruta de patrullaje.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>CGuardPro Supervisor usa el micrófono para grabar notas de voz.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>CGuardPro Supervisor puede guardar imágenes en tu galería.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>CGuardPro comparte tu ubicación con la central mientras estás en turno para el seguimiento en vivo y el recorrido de tu ronda, incluso con la pantalla apagada.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>CGuardPro Supervisor usa tu galería para adjuntar fotos de verificación en las paradas.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>CGuardPro Supervisor usa el reconocimiento de voz para dictar notas por texto.</string>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
</dict>
</plist>
